.exercise-container {
  margin-top: 40px;
  padding: 20px;
  border: 2px solid #ccc;
  border-radius: 10px;
  background-color: #f9f9f9;
}

.para {
  background-color: #282c34;
  color: white;
  padding: 40px;
  font-family: Arial;
  text-align: center;
  border-radius: 8px;
  margin: 20px 0;
}

/* app global styles */
.App {
  text-align: center;
}

.App-header {
  background-color: #282c34;
  padding: 40px;
  color: white;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: calc(10px + 2vmin);
}

.user-info {
  margin: 30px 0;
  background: rgba(255,255,255,0.1);
  padding: 20px;
  border-radius: 10px;
}

.favorite-animals ul {
  list-style: none;
  padding: 0;
}

.favorite-animals li {
  background: #61dafb;
  margin: 5px 0;
  padding: 10px;
  border-radius: 5px;
  color: #282c34;
  font-weight: bold;
}

form {
  margin: 20px 0;
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
}

input, button {
  padding: 10px;
  border: 1px solid #ccc;
  border-radius: 5px;
}

button {
  background-color: #61dafb;
  cursor: pointer;
}

button:hover {
  background-color: #21b0d6;
}
